{
  "name": "NoFusion",
  "version": "0.1.0",
  "language": "zh",
  "llm": {
    "provider": "openai",
    "service": "deepseek",
    "configSource": "studio",
    "proxyUrl": "http://127.0.0.1:7897",
    "baseUrl": "https://api.deepseek.com",
    "model": "deepseek-v4-flash",
    "apiFormat": "chat",
    "stream": true,
    "services": [
      {
        "service": "deepseek",
        "temperature": 0.7,
        "apiFormat": "chat",
        "stream": true
      },
      {
        "service": "moonshot",
        "temperature": 0.7,
        "apiFormat": "chat",
        "stream": true
      },
      {
        "service": "volcengine",
        "temperature": 0.7,
        "apiFormat": "chat",
        "stream": true,
        "extra": {
          "top_p": 1,
          "presence_penalty": 0,
          "frequency_penalty": 0,
          "repetition_penalty": 1
        }
      },
      {
        "service": "openai",
        "temperature": 0.7,
        "apiFormat": "chat",
        "stream": true,
        "extra": {
          "top_p": 1,
          "presence_penalty": 0,
          "frequency_penalty": 0,
          "repetition_penalty": 1
        }
      },
      {
        "service": "kimicode",
        "temperature": 0.7,
        "apiFormat": "chat",
        "stream": true,
        "extra": {
          "top_p": 1,
          "presence_penalty": 0,
          "frequency_penalty": 0,
          "repetition_penalty": 1
        }
      }
    ],
    "defaultModel": "gpt-5.5",
    "temperature": 0.7,
    "extra": {
      "top_p": 1,
      "presence_penalty": 0,
      "frequency_penalty": 0,
      "repetition_penalty": 1
    }
  },
  "notify": [],
  "inputGovernanceMode": "v2",
  "daemon": {
    "schedule": {
      "radarCron": "0 */6 * * *",
      "writeCron": "*/15 * * * *"
    },
    "maxConcurrentBooks": 3
  },
  "modelOverrides": {
    "writer": "deepseek-v4-flash",
    "planner": "deepseek-v4-flash",
    "auditor": "deepseek-v4-flash",
    "reviser": "deepseek-v4-flash",
    "detector": "deepseek-v4-flash",
    "architect": "deepseek-v4-flash",
    "style": "deepseek-v4-flash"
  }
}