{
  "name": "inkos",
  "version": "1.5.0",
  "private": true,
  "description": "Autonomous AI novel writing CLI agent — 10-agent pipeline that writes, audits, and revises novels with continuity tracking",
  "keywords": [
    "ai-novel-writing",
    "ai-writing-agent",
    "novel-generator",
    "autonomous-writing",
    "litrpg",
    "progression-fantasy",
    "multi-agent",
    "creative-writing-ai",
    "openclaw-skill",
    "cli"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Narcooo/inkos"
  },
  "scripts": {
    "build": "pnpm --filter @actalk/inkos-core build && pnpm --filter @actalk/inkos-studio build && pnpm --filter @actalk/inkos build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm build && pnpm -r --workspace-concurrency=1 test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "verify:publish-manifests": "node scripts/verify-no-workspace-protocol.mjs packages/core packages/cli packages/studio",
    "release": "pnpm typecheck && pnpm build && pnpm test && pnpm verify:publish-manifests"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.5.2",
  "dependencies": {
    "pnpm": "^11.5.2"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "@eslint/js": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
