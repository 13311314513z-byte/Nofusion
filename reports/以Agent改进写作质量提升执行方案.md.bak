全书级意图模型：

```typescript
export interface StoryIntent {
  readonly corePremise: string;         // 故事核心 premise
  readonly thematicStatement: string;   // 主题陈述
  readonly readerJourney: {
    readonly arc: EmotionalArc[];
    readonly promiseToReader: string;
  };
  readonly characterArcs: CharacterArc[];
  readonly pacingBlueprint: {
    readonly earlyChapters: PacingMode;
    readonly midChapters: PacingMode;
    readonly lateChapters: PacingMode;
  };
}
```

存储：`books/<bookId>/story/story_intent.json`

**新建** `packages/core/src/agents/narrative-director.ts`

```typescript
export class NarrativeDirector extends BaseAgent {
  get name(): string { return "narrative-director"; }

  async getDirectorNote(input: {
    readonly storyIntent: StoryIntent;
    readonly chapterNumber: number;
    readonly bookDir: string;
  }): Promise<DirectorNote> {
    // 1. 加载全书意图
    // 2. 确定当前章在全书中位置
    // 3. 确定当前弧线进度
    // 4. 生成 DirectorNote
  }
}

export interface DirectorNote {
  readonly chapterFunction: "setup" | "escalate" | "twist" | "climax" | "resolve";
  readonly arcProgress: {
    readonly arcName: string;
    readonly overallBeatCount: number;
    readonly completedBeats: number;
  };
  readonly activeCharacterArcs: Array<{
    readonly characterId: string;
    readonly beliefAtStart: string;
    readonly expectedShift: string;
  }>;
  readonly recommendedPacing: {
    readonly tensionLevel: "low" | "medium" | "high";
    readonly infoRevealRate: "slow" | "normal" | "fast";
  };
}
```

